{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "build",
		"lib": ["ES2021", "DOM"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"types": ["@types/node"],
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src/**/*.ts", "syntaxes/**/*.json", "themes/**/*.json"],
	"exclude": ["node_modules", "build", "scripts"],
	"references": [
		{
			"path": "../language-core/tsconfig.json"
		}
	]
}
