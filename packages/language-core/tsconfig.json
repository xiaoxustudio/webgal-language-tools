{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"outDir": "build",
		"rootDir": "src",
		"module": "esnext",
		"moduleResolution": "bundler",
		"composite": true,
		"types": ["node"],
		"verbatimModuleSyntax": true,
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "build", "scripts"]
}
