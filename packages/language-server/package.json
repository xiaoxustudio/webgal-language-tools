{
	"name": "@webgal/language-server",
	"version": "0.1.0",
	"main": "build/node.cjs",
	"module": "build/node.mjs",
	"types": "build/node.d.mts",
	"type": "module",
	"license": "MPL-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/xiaoxustudio/webgal-language-tools.git",
		"directory": "packages/language-server"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"files": [
		"build/**/*",
		"bin"
	],
	"exports": {
		".": {
			"types": "./build/index.d.mts",
			"browser": "./build/browser.mjs",
			"import": "./build/node.mjs",
			"require": "./build/node.cjs"
		},
		"./utils": {
			"types": "./build/utils.d.mts",
			"import": "./build/utils.mjs",
			"require": "./build/utils.cjs"
		},
		"./browser": {
			"types": "./build/browser.d.mts",
			"import": "./build/browser.mjs",
			"require": "./build/browser.cjs"
		},
		"./browser-worker": {
			"types": "./build/browser.worker.d.mts",
			"import": "./build/browser.worker.mjs",
			"require": "./build/browser.worker.cjs"
		},
		"./node": {
			"types": "./build/node.d.mts",
			"import": "./build/node.mjs",
			"require": "./build/node.cjs"
		}
	},
	"bin": {
		"webgal-lsp": "./bin/webgal-language-server.cjs"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "pnpm build && npx webgal-lsp --stdio",
		"dev:ws": "pnpm build && npx webgal-lsp --ws",
		"format": " prettier --write \"src/**/*.ts\"",
		"lint": "eslint \"src/**/*.ts\" --fix",
		"typecheck": "tsc --noEmit",
		"watch": "tsdown --watch"
	},
	"dependencies": {
		"@volar/language-core": "~2.4.0",
		"@volar/language-server": "~2.4.0",
		"@volar/language-service": "~2.4.0",
		"@volar/typescript": "~2.4.0",
		"@webgal/language-core": "workspace:*",
		"@webgal/language-service": "workspace:*",
		"vscode-languageserver": "^9.0.1",
		"vscode-languageserver-textdocument": "^1.0.11",
		"vscode-uri": "^3.0.8",
		"vscode-ws-jsonrpc": "^3.4.0",
		"ws": "^8.18.3"
	},
	"devDependencies": {
		"@types/ws": "^8.18.1",
		"tsdown": "catalog:",
		"tsx": "^4.21.0"
	}
}
