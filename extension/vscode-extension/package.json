{
	"private": true,
	"name": "webgal-for-vscode",
	"version": "2.0.3",
	"repository": {
		"type": "git",
		"url": "https://github.com/xiaoxustudio/webgal-language-tools.git",
		"directory": "packages/vscode"
	},
	"categories": [
		"Programming Languages",
		"Formatters",
		"Debuggers",
		"Snippets"
	],
	"displayName": "%displayName%",
	"description": "%description%",
	"author": "xuran",
	"publisher": "Xuran1783558957",
	"engines": {
		"vscode": "^1.82.0"
	},
	"activationEvents": [
		"workspaceContains:**/game/config.txt"
	],
	"main": "./build/extension.js",
	"icon": "./resources/icon.png",
	"contributes": {
		"marks": [
			"markdownString"
		],
		"languages": [
			{
				"id": "webgal",
				"extensions": [],
				"filenamePatterns": [
					"**/game/scene/**/*.txt"
				],
				"aliases": [
					"webgal",
					"webgalscript",
					"webgalScript",
					"webgal script",
					"webgal Script",
					"webgal-Script",
					"webgal-script"
				],
				"icon": {
					"dark": "./resources/icon_script.png",
					"light": "./resources/icon_script.png"
				},
				"configuration": "./syntaxes/language-configuration.json"
			},
			{
				"id": "webgal-config",
				"extensions": [],
				"aliases": [
					"webgal-config",
					"webgal-Config",
					"webgalConfig",
					"webgalconfig",
					"webgal Config",
					"webgal config"
				],
				"filenamePatterns": [
					"**/game/config.txt"
				],
				"icon": {
					"dark": "./resources/icon_config.png",
					"light": "./resources/icon_config.png"
				},
				"configuration": "./syntaxes/language-configuration.json"
			}
		],
		"commands": [
			{
				"title": "%extension.goToDefinition%",
				"command": "extension.goToDefinition"
			},
			{
				"title": "%extension.StartWFV%",
				"command": "extension.StartWFV"
			},
			{
				"title": "%extension.RunLineScript%",
				"command": "extension.RunLineScript"
			},
			{
				"title": "%extension.initFmtConfig%",
				"command": "extension.initFmtConfig"
			}
		],
		"menus": {
			"editor/context": [
				{
					"when": "resourceLangId == webgal",
					"command": "extension.RunLineScript",
					"group": "%webgal for vscode%"
				}
			]
		},
		"debuggers": [
			{
				"type": "webgal",
				"label": "%Webgal Debug%",
				"program": "./build/DebugAdapter.js",
				"runtime": "node",
				"configurationAttributes": {
					"launch": {
						"required": [
							"program"
						],
						"properties": {
							"program": {
								"type": "string",
								"description": "%debugger.program.description%",
								"default": "${fileBasename}"
							},
							"ws": {
								"type": "string",
								"description": "%debugger.ws.description%",
								"default": "ws://localhost:3001/api/webgalsync"
							}
						}
					}
				},
				"initialConfigurations": [
					{
						"type": "webgal",
						"request": "launch",
						"name": "%Launch Webgal Script%",
						"program": "${fileBasename}",
						"ws": "ws://localhost:3001/api/webgalsync"
					}
				],
				"configurationSnippets": [
					{
						"label": "%webgal Debug: Launch%",
						"description": "%webgal Debug: Launch.description%",
						"body": {
							"type": "webgal",
							"request": "launch",
							"name": "${2:Launch Webgal Script}",
							"program": "${fileBasename}",
							"ws": "ws://localhost:3001/api/webgalsync"
						}
					}
				]
			}
		],
		"configuration": {
			"type": "object",
			"title": "%configuration.title%",
			"properties": {
				"WebGalLanguageServer.maxNumberOfProblems": {
					"scope": "resource",
					"type": "number",
					"default": 500,
					"description": "%WebGalLanguageServer.maxNumberOfProblems.description%"
				},
				"WebGalLanguageServer.isShowWarning": {
					"scope": "resource",
					"type": "boolean",
					"default": true,
					"description": "%WebGalLanguageServer.isShowWarning.description%"
				},
				"WebGalLanguageServer.isShowHint": {
					"scope": "resource",
					"type": "string",
					"enum": [
						"%WebGalLanguageServer.isShowHint.enum0%",
						"%WebGalLanguageServer.isShowHint.enum1%",
						"%WebGalLanguageServer.isShowHint.enum2%",
						"%WebGalLanguageServer.isShowHint.enum3%",
						"%WebGalLanguageServer.isShowHint.enum4%"
					],
					"default": "%WebGalLanguageServer.isShowHint.default%",
					"description": "%WebGalLanguageServer.isShowHint.description%"
				},
				"WebGalLanguageServer.isShowImagePreview": {
					"scope": "resource",
					"type": "boolean",
					"default": true,
					"description": "%WebGalLanguageServer.isShowImagePreview.description%"
				}
			}
		},
		"grammars": [
			{
				"language": "webgal",
				"scopeName": "source.webgal",
				"path": "./syntaxes/webgal.tmLanguage.json"
			},
			{
				"language": "webgal-config",
				"scopeName": "source.webgal-config",
				"path": "./syntaxes/webgal-config.tmLanguage.json"
			}
		]
	},
	"scripts": {
		"build": "rolldown --config rolldown.config.mts",
		"watch": "pnpm run build --watch",
		"pack": "pnpm run build && pnpx @vscode/vsce package --no-dependencies",
		"release": "pnpm run build && vsce publish --pre-release",
		"publish": "pnpx @vscode/vsce publish --no-dependencies",
		"format": " prettier --write \"src/**/*.ts\"",
		"lint": "eslint src --ext ts --fix",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^25.2.2",
		"@types/vscode": "^1.82.0",
		"@types/ws": "^8.5.10",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"@volar/language-server": "~2.4.0",
		"@volar/vscode": "~2.4.0",
		"@vscode/vsce": "latest",
		"concurrently": "^9.2.1",
		"esbuild": "latest",
		"esbuild-plugin-alias": "^0.2.1",
		"eslint": "^8.56.0",
		"prettier": "^3.8.1",
		"rolldown": "^1.0.1",
		"tsx": "^4.21.0",
		"typescript": "catalog:"
	},
	"dependencies": {
		"@vscode/debugadapter": "^1.65.0",
		"@webgal/language-core": "workspace:*",
		"@webgal/language-server": "workspace:*",
		"@webgal/language-service": "workspace:*",
		"angular-expressions": "^1.5.1",
		"vscode-debugadapter": "^1.51.0",
		"vscode-debugprotocol": "^1.51.0",
		"vscode-languageclient": "^9.0.1",
		"vscode-languageserver": "^9.0.1",
		"vscode-languageserver-textdocument": "^1.0.11",
		"webgal-parser": "^4.5.18",
		"ws": "^8.17.1"
	}
}
